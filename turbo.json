{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "FLAGCODE_LOG_WS_EVENTS",
    "FLAGCODE_MODE",
    "FLAGCODE_PORT",
    "FLAGCODE_NO_BROWSER",
    "FLAGCODE_HOME",
    "FLAGCODE_AUTH_TOKEN",
    "FLAGCODE_DESKTOP_WS_URL",
    "FLAGCODE_TRACE_MIN_LEVEL",
    "FLAGCODE_TRACE_TIMING_ENABLED",
    "FLAGCODE_TRACE_FILE",
    "FLAGCODE_TRACE_MAX_BYTES",
    "FLAGCODE_TRACE_MAX_FILES",
    "FLAGCODE_TRACE_BATCH_WINDOW_MS",
    "FLAGCODE_OTLP_TRACES_URL",
    "FLAGCODE_OTLP_METRICS_URL",
    "FLAGCODE_OTLP_EXPORT_INTERVAL_MS",
    "FLAGCODE_OTLP_SERVICE_NAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@flagcode/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
